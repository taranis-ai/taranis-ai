FROM python:3.13-slim

COPY --from=ghcr.io/astral-sh/uv:0.11.18@sha256:78bc42400d77b0678ba95765305c826652ed5431f399257271dda681d0318f03 /uv /bin/uv

ENV DEBIAN_FRONTEND=noninteractive \
    UV_PROJECT_ENVIRONMENT=/opt/loadtest/.venv \
    UV_LINK_MODE=copy \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PYTHONUNBUFFERED=1

WORKDIR /opt/loadtest

COPY src/frontend/tests/load/pyproject.toml src/frontend/tests/load/uv.lock ./

RUN uv sync --frozen --no-dev --no-editable && \
    /opt/loadtest/.venv/bin/playwright install --with-deps chromium

ENV PATH="/opt/loadtest/.venv/bin:${PATH}"
