{
  "nodeModulesDir": "auto",
  "imports": {
    "@tailwindcss/cli": "npm:@tailwindcss/cli@^4.2.4",
    "alpinejs": "npm:alpinejs@^3.15.11",
    "choices.js": "npm:choices.js@^11.2.2",
    "daisyui": "npm:daisyui@^5.5.19",
    "fuse.js": "npm:fuse.js@^7.3.0",
    "highlight-search-term": "npm:highlight-search-term@^1.0.3",
    "htmx-ext-response-targets": "npm:htmx-ext-response-targets@^2.0.4",
    "htmx.org": "npm:htmx.org@^2.0.9",
    "sortablejs": "npm:sortablejs@^1.15.7",
    "sweetalert2": "npm:sweetalert2@^11.26.24",
    "tailwindcss": "npm:tailwindcss@^4.2.4",
    "@codemirror/state": "npm:@codemirror/state@^6.6.0",
    "@codemirror/view": "npm:@codemirror/view@^6.41.1",
    "@codemirror/commands": "npm:@codemirror/commands@^6.10.3",
    "@codemirror/language": "npm:@codemirror/language@^6.12.3",
    "@codemirror/legacy-modes": "npm:@codemirror/legacy-modes@^6.5.2",
    "@codemirror/merge": "npm:@codemirror/merge@^6.12.1",
    "codemirror": "npm:codemirror@^6.0.2"  },
  "tasks": {
    "tw:build": "deno run -A npm:@tailwindcss/cli -i frontend/static/css/input.css -o frontend/static/css/tailwind.css --minify",
    "tw:watch": "deno run -A npm:@tailwindcss/cli -i frontend/static/css/input.css -o frontend/static/css/tailwind.css --watch",
    "vendor:bundle": "deno bundle --sourcemap=inline --platform=browser --minify --output frontend/static/vendor/vendor.bundle.js vendor.js",
    "vendor:bundle:codemirror": "deno bundle --sourcemap=inline --platform=browser --minify --output frontend/static/vendor/codemirror.js vendor_codemirror.js"
  }
}
