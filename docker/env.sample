COMPOSE_PROJECT_NAME=taranis
TARANIS_TAG=latest
DOCKER_IMAGE_NAMESPACE=ghcr.io/taranis-ai

TARANIS_PORT=8080
GRANIAN_PORT=8080

# Default passwords. CHANGE THESE FOR PRODUCTION!
POSTGRES_PASSWORD=supersecret
JWT_SECRET_KEY=supersecret
API_KEY=supersecret
BOT_API_KEY=supersecret
REDIS_PASSWORD=supersecret

# Optional llm-bot settings for summary, NER and story clustering.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=120

# Optional dedicated frontend cache settings. When unset, frontend/core fall back to REDIS_URL and REDIS_PASSWORD.
# CACHE_ENABLED=true
# CACHE_REDIS_URL=redis://redis:6379/0
# CACHE_REDIS_PASSWORD=supersecret
